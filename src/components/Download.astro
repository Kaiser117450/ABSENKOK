---
// Download.astro — Full-width CTA section with gradient background
---

<section id="download" class="relative bg-brand-navy pt-40 lg:pt-52 pb-20 lg:pb-28 overflow-hidden">
  <!-- Decorative background blurs -->
  <div class="absolute top-0 left-1/4 w-72 h-72 bg-brand-teal/20 rounded-full blur-[80px]"></div>
  <div class="absolute bottom-0 right-1/4 w-64 h-64 bg-brand-pink/15 rounded-full blur-[60px]"></div>

  <div class="relative max-w-3xl mx-auto px-6 text-center" style="animation: fade-in-up 0.6s ease-out both;">
    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
      Siap Digitalisasi Absensi Restoran Anda?
    </h2>
    <p class="mt-6 text-lg leading-8 text-brand-teal-light/80">
      Download ABSENKOK gratis dan mulai kelola kehadiran karyawan dengan NFC.
    </p>
    <div class="mt-10">
      <a
        href="https://github.com/Kaiser117450/ABSENKOK/releases"
        class="group inline-flex items-center gap-2 bg-brand-pink text-white rounded-full px-10 py-4 text-lg font-bold shadow-xl shadow-brand-pink/25 hover:bg-brand-pink-dark hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-300"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-y-0.5 transition-transform duration-300">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download APK Gratis
      </a>
    </div>
  </div>
</section>
