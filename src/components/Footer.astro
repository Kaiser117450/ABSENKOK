---
// Footer.astro — Dark footer with copyright, developer credit + AKM LAB logo
import { Image } from 'astro:assets';
import akmLabLogo from '../assets/images/akmlav.png';

const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-navy-dark py-12 border-t border-brand-navy">
  <div class="max-w-7xl mx-auto px-6 flex flex-col items-center gap-4">
    <!-- Logo -->
    <a href="/" class="text-lg font-extrabold tracking-tight mb-2">
      <span class="text-brand-pink">ABSEN</span><span class="text-white">KOK</span>
    </a>
    <p class="text-sm text-brand-teal-light/60">
      &copy; {currentYear} ABSENKOK. Sistem Absensi NFC untuk Restoran.
    </p>
    <!-- Developer credit with AKM LAB logo -->
    <div class="flex items-center gap-2">
      <p class="text-xs text-brand-teal-light/40">
        Dibuat oleh <span class="font-semibold text-brand-teal-light/70">Akmal</span>
      </p>
      <span class="text-brand-teal-light/20">|</span>
      <Image
        src={akmLabLogo}
        alt="AKM LAB."
        width={56}
        class="h-4 w-auto opacity-50 hover:opacity-80 transition-opacity duration-300"
      />
    </div>
  </div>
</footer>
