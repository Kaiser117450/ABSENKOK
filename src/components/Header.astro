---
// Header.astro — Sticky navigation with brand logo (rounded image) + anchor links
import { Image } from 'astro:assets';
import absenkokLogo from '../assets/images/ABSENKOK.png';
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-brand-border">
  <nav class="max-w-7xl mx-auto px-6 flex items-center justify-between h-16">
    <!-- Brand Logo -->
    <a href="/" class="flex items-center gap-2.5">
      <Image
        src={absenkokLogo}
        alt="ABSENKOK"
        width={36}
        class="h-9 w-9 rounded-xl shadow-sm ring-1 ring-brand-border"
      />
      <span class="text-xl font-extrabold tracking-tight">
        <span class="text-brand-pink">ABSEN</span><span class="text-brand-navy">KOK</span>
      </span>
    </a>

    <!-- Nav Links (hidden on mobile) -->
    <ul class="hidden md:flex items-center gap-8">
      <li>
        <a href="#fitur" class="text-sm font-medium text-brand-text-secondary hover:text-brand-pink transition-colors duration-300">
          Fitur
        </a>
      </li>
      <li>
        <a href="#cara-kerja" class="text-sm font-medium text-brand-text-secondary hover:text-brand-pink transition-colors duration-300">
          Cara Kerja
        </a>
      </li>
      <li>
        <a href="#arsitektur" class="text-sm font-medium text-brand-text-secondary hover:text-brand-pink transition-colors duration-300">
          Arsitektur
        </a>
      </li>
      <li>
        <a href="#download" class="inline-flex items-center gap-1.5 text-sm font-semibold text-white bg-brand-pink rounded-full px-5 py-2 hover:bg-brand-pink-dark transition-colors duration-300 shadow-sm hover:shadow-md">
          Download
        </a>
      </li>
    </ul>
  </nav>
</header>
